# ============================================================
# kerbal.ru perf-профиль — КАНАЛ C: общий фрагмент settings.cfg
# Мерджится приёмом sed-по-ключу (как LANGUAGE=ru) в стоковый
# <KSP>/settings.cfg ПЕРЕД запуском игры, при закрытой игре.
# Значения — консервативно-низкие, безопасные для ЛЮБОГО железа.
# Формат строк: "KEY = VALUE" (ровно как в settings.cfg). # — комментарий.
# Профильные (mac/deck/generic-low) значения — в одноимённых .env;
# они применяются ПОВЕРХ этого файла. Наборы ключей не пересекаются.
# ============================================================

# Обёртка-пресет качества: 1 = Low. Форсируем низкий базовый пресет
# (на незнакомой машине мог стоять High/Default). НЕ пересчитывает
# под-настройки сам — поэтому все графические ключи задаём явно ниже.
QUALITY_PRESET = 1

# Сглаживание кромок движком: 0 = выкл. Лесенки гасит SMAA от Scatterer,
# дублировать дорогим MSAA незачем. Даёт: GPU. Теряется: ничего (SMAA есть).
ANTI_ALIASING = 0

# Глобальный mip-bias текстур: 2 = Quarter. Даунсемплит RSS-текстуры в VRAM
# (8K->~2K, 4K->~1K) — всегда самый лёгкий по памяти вариант, не зависит от
# того, какой RSSTextures-пак стоит. Даёт: VRAM/RAM. Теряется: резкость частей.
# ВНИМАНИЕ: mac НЕ понижаем до 1 — по докам это безопасно только вместе с
# 4K-паком (канал A/CKAN), а фрагмент settings.cfg не может проверить, что
# своп текстур удался. Держим консервативный Quarter для всех.
TEXTURE_QUALITY = 2

# Шейдер террейна: 0 = Low. Ultra-шейдер поверхности очень дорогой.
# Даёт: GPU. Теряется: детализация грунта вблизи (и так уже минимум).
TERRAIN_SHADER_QUALITY = 0

# Наземный скаттер (камни/трава на поверхности): выкл.
# Даёт: GPU/CPU у поверхности. Теряется: декоративные камни/трава.
PLANET_SCATTER = False

# Вертикальная синхронизация: 1 = вкл. Кап по частоте монитора, меньше
# тиринга и лишнего нагрева GPU. Даёт: ровнее frametime/нагрев. Теряется: —.
# (На Deck предпочтительнее лимитер Steam, но игровой vsync не мешает.)
SYNC_VBL = 1

# Качество аэро-эффектов (плазма/вход в атмосферу): 3 -> 2.
# Даёт: небольшой GPU на входе/взлёте. Теряется: детализация плазмы.
AERO_FX_QUALITY = 2

# Проекция теней в редакторе (VAB/SPH): 1 -> 0. Не по геймплею.
# Даёт: GPU в редакторе. Теряется: тени в сборочном цехе (косметика).
SHADOWS_EDITORS_PROJECTION = 0

# Лимит «догоняющих» физ-шагов на кадр (Unity Time.maximumDeltaTime):
# 0.04 -> 0.03. НЕ меняет шаг физики — ограничивает catch-up на медленном
# кадре. Даёт: стабильнее физика, меньше вобла RO-ракет (важно на Mac/Rosetta
# и слабых машинах). Теряется: под тяжёлой нагрузкой чуть больше slow-mo.
# Безопасный диапазон RO 0.03-0.05; 0.03 безопасно т.к. в сборке есть KJR+KSPCF.
PHYSICS_FRAME_DT_LIMIT = 0.03
