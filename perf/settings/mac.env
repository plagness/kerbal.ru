# ============================================================
# kerbal.ru perf-профиль — КАНАЛ C: Mac (Apple Silicon / Rosetta)
# Применяется ПОВЕРХ common.env. Узкое место Mac — устаревший Apple OpenGL
# (Metal у KSP нет) -> агрессивно режем GPU-стоимость теней, но сами тени
# ОСТАВЛЯЕМ (не Deck-уровень) и физику сверх common не трогаем.
# ============================================================

# Качество/каскады теней: 4 -> 2. Крупнейший GPU-выигрыш на Mac (вид на
# поверхность Земли/КЦ). Даёт: GPU (высокий). Теряется: тени грубее/мягче.
SHADOWS_QUALITY = 2

# Пиксельные источники света: держим 8 (по докам на Mac профит низкий —
# оставляем качество освещения). Даёт: —. Теряется: —.
LIGHT_QUALITY = 8

# Разрешение отражений на корпусе: держим 1 (Mac оставляет отражения).
# Даёт: —. Теряется: —.
REFLECTION_PROBE_TEXTURE_RESOLUTION = 1

# Проекция «главных» теней (меню/загрузочная сцена): держим 1.
# Даёт: —. Теряется: —.
SHADOWS_MAIN_PROJECTION = 1

# Тени затмений от небесных тел: держим вкл (косметика затмений, на Mac ок).
CELESTIAL_BODIES_CAST_SHADOWS = True

# Кап кадров: 60. В тяжёлых RSS-сценах Mac всё равно не выдаёт больше; кап
# ровняет frametime и снижает нагрев ноутбука. Теряется: —.
# (Для батареи оператор может опустить до 30.)
FRAMERATE_LIMIT = 60

# Бюджет одновременно симулируемых аппаратов: держим стоковые 250.
MAX_VESSELS_BUDGET = 250
