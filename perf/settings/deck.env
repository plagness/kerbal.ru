# ============================================================
# kerbal.ru perf-профиль — КАНАЛ C: Steam Deck (RDNA2 APU, 15 Вт, shared RAM)
# Применяется ПОВЕРХ common.env. Узкое место — GPU и общая память ->
# режем сильнее всего: тени в минимум, отражения/затмения off, кап 30 FPS.
# Питание/TDP/GPU-clock/FSR — НЕ в settings.cfg (это Game Mode), см. perf/README.
# ============================================================

# Качество/каскады теней: 4 -> 1 (минимум с тенями). Для 15 Вт APU — разница
# между слайд-шоу и играбельностью. Даёт: GPU (высокий). Теряется: тени очень
# грубые.
SHADOWS_QUALITY = 1

# Пиксельные источники света: 8 -> 4. Даёт: GPU.
# Теряется: меньше одновременных пиксельных источников света.
LIGHT_QUALITY = 4

# Разрешение отражений на корпусе: 1 -> 0. Даёт: GPU/VRAM.
# Теряется: отражения на корпусе заметно грубее.
REFLECTION_PROBE_TEXTURE_RESOLUTION = 0

# Проекция «главных» теней (меню/загрузочная сцена): 1 -> 0.
# Даёт: GPU. Теряется: тени в меню (не по геймплею).
SHADOWS_MAIN_PROJECTION = 0

# Тени затмений от небесных тел: выкл. Даёт: GPU.
# Теряется: тени затмений (косметика).
CELESTIAL_BODIES_CAST_SHADOWS = False

# Кап кадров: 30. LCD 60 Гц; в сложных сценах KSP всё равно не выдаст больше —
# кап убирает judder и жор батареи/тепло.
FRAMERATE_LIMIT = 30

# Бюджет одновременно симулируемых аппаратов: 250 -> 150. Снижает фоновую
# нагрузку Kerbalism на слабый CPU. ФЛАГ: при большом флоте часть дальних
# аппаратов может не симулироваться — оператору проверить приемлемость.
# Теряется: запас на большой флот/обломки.
MAX_VESSELS_BUDGET = 150
