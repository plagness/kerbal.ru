# ============================================================
# kerbal.ru perf-профиль — КАНАЛ C: generic-low (неизвестный Linux/Win десктоп)
# Применяется ПОВЕРХ common.env. Железо неизвестно -> консервативно-низкий,
# безопасный, но НЕ калечащий: берём дешёвые «невидимые» урезания (свет,
# отражения), но тени оставляем средними и бюджет аппаратов не трогаем.
# ============================================================

# Качество/каскады теней: 4 -> 2. Заметный GPU-выигрыш, но тени остаются
# (не Deck-уровень 1). Даёт: GPU. Теряется: тени грубее/мягче.
SHADOWS_QUALITY = 2

# Пиксельные источники света: 8 -> 4. Дешёвое урезание.
# Даёт: GPU. Теряется: меньше одновременных пиксельных источников света.
LIGHT_QUALITY = 4

# Разрешение отражений на корпусе: 1 -> 0. Дешёвое, почти незаметное урезание.
# Даёт: GPU/VRAM. Теряется: отражения на корпусе грубее.
REFLECTION_PROBE_TEXTURE_RESOLUTION = 0

# Проекция «главных» теней (меню/загрузочная сцена): держим 1 — не режем
# косметику меню на потенциально годном железе. Даёт: —. Теряется: —.
SHADOWS_MAIN_PROJECTION = 1

# Тени затмений от небесных тел: держим вкл (не калечим визуал вслепую).
CELESTIAL_BODIES_CAST_SHADOWS = True

# Кап кадров: 60. Ровнее frametime и меньше нагрев без заметной потери.
# ФЛАГ: если у пользователя мощный GPU + монитор >60 Гц, кап снизит потолок —
# оператору решить, оставлять ли кап в generic-профиле.
FRAMERATE_LIMIT = 60

# MAX_VESSELS_BUDGET НЕ трогаем (остаётся стоковый 250) — на незнакомой машине
# не рискуем перестать симулировать аппараты игрока.
